# Port configuration
PORT=5000

# Environment type (development, production, test)
NODE_ENV=development

# Frontend Client URL
CLIENT_URL=http://localhost:5173

# Database Connection URI (MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority

# JWT Credentials
JWT_SECRET=your_jwt_access_token_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_min_32_chars

# Third Party Integrations (Google OAuth & Gemini APIs - Planned for Phase 3)
GOOGLE_CLIENT_ID=google_client_id_placeholder
GOOGLE_CLIENT_SECRET=google_client_secret_placeholder
GEMINI_API_KEY=gemini_api_key_placeholder

# Payment Gateway Keys (Razorpay - Planned for Phase 3)
RAZORPAY_KEY_ID=rzp_test_key_id_placeholder
RAZORPAY_KEY_SECRET=rzp_test_key_secret_placeholder
